# =====================================================
# ImmortalWrt 24.10 X86/64 配置文件
# By Russell Lee
# =====================================================

# 目标平台
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_generic=y
CONFIG_TARGET_x86_generic_DEVICE=y

# 内核版本
CONFIG_KERNEL_6_6=y

# =====================================================
# 主题配置
# =====================================================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# =====================================================
# LuCI 基础
# =====================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-lib-httpclient=y
CONFIG_PACKAGE_luci-lib-httpprotoutils=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-docker=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-dashboard=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y

# 中文语言包
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# =====================================================
# 科学上网/代理
# =====================================================
CONFIG_PACKAGE_luci-app-homeproxy=y

# =====================================================
# DNS 配置
# =====================================================
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-app-nextdns=y
CONFIG_PACKAGE_smartdns=y

# =====================================================
# 下载工具
# =====================================================
CONFIG_PACKAGE_luci-app-qbittorrent=y
CONFIG_PACKAGE_qbittorrent-nox=y
CONFIG_PACKAGE_luci-app-filebrowser=y
CONFIG_PACKAGE_filebrowser=y

# =====================================================
# 内网穿透
# =====================================================
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_frpc=y
CONFIG_PACKAGE_luci-app-frps=y
CONFIG_PACKAGE_frps=y

# =====================================================
# 网络工具
# =====================================================
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_luci-app-wol=y

# =====================================================
# 系统工具
# =====================================================
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_blkid=y

# =====================================================
# 安全/防火墙
# =====================================================
CONFIG_PACKAGE_luci-app-banip=y
CONFIG_PACKAGE_banip=y

# =====================================================
# 监控工具
# =====================================================
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_nlbwmon=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-conntrack=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-df=y
CONFIG_PACKAGE_collectd-mod-disk=y
CONFIG_PACKAGE_collectd-mod-ethstat=y
CONFIG_PACKAGE_collectd-mod-irq=y
CONFIG_PACKAGE_collectd-mod-iwinfo=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_collectd-mod-ping=y
CONFIG_PACKAGE_collectd-mod-processes=y
CONFIG_PACKAGE_collectd-mod-rrdtool=y
CONFIG_PACKAGE_collectd-mod-swap=y
CONFIG_PACKAGE_collectd-mod-thermal=y
CONFIG_PACKAGE_collectd-mod-wireless=y

# =====================================================
# USB/存储支持
# =====================================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152-vendor=y

# =====================================================
# 文件系统
# =====================================================
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_kmod-squashfs=y
CONFIG_PACKAGE_kmod-fuse=y
CONFIG_PACKAGE_fuse-utils=y

# =====================================================
# 网络加速
# =====================================================
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-fullconenat=y

# =====================================================
# 无线驱动 (X86 可能需要)
# =====================================================
CONFIG_PACKAGE_kmod-ath10k-ct=y
CONFIG_PACKAGE_kmod-iwlwifi=y
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-btmrvl=y
CONFIG_PACKAGE_kmod-r8168=y
CONFIG_PACKAGE_kmod-r8101=y
CONFIG_PACKAGE_kmod-r8125=y

# =====================================================
# 基础工具
# =====================================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_vim=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_git=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-ipt-raw=y

# =====================================================
# 作者/版本信息
# =====================================================
CONFIG_VERSION_DIST="ImmortalWrt"
CONFIG_VERSION_MANUFACTURER="Russell Lee"
CONFIG_VERSION_PRODUCT="ImmortalWrt X86/64"
CONFIG_VERSION_MODEL="X86/64"
CONFIG_VERSION_SUPPORT_URL="https://github.com/RussellLee-immortalwrt"
CONFIG_VERSION_BUG_URL="https://github.com/RussellLee-immortalwrt/issues"

# =====================================================
# 优化选项
# =====================================================
CONFIG_DEVEL=y
CONFIG_TOOLCHAINOPTS=y
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_AFALG_UPDATE=y
CONFIG_AIO=y
CONFIG_IPV6=y
CONFIG_KERNEL_AIO=y
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_NET_CLS_CGROUP=y
CONFIG_PACKAGE_ipv6helper=y

# =====================================================
# 禁用不需要的包
# =====================================================
# CONFIG_PACKAGE_autocore is not set
# CONFIG_PACKAGE_default-settings-chn is not set
# CONFIG_PACKAGE_luci-app-docker is not set
